#!/bin/sh

#
# @name Flying ground robot (DogCopter hybrid)
#
# @type Quadrotor
#
# ID 4030: was 4002, renumbered because stock 4002_gz_x500_depth collides
# with it and rcS picks a ${SYS_AUTOSTART}_* match by glob order.

. ${R}etc/init.d/rc.mc_defaults

PX4_SIMULATOR=${PX4_SIMULATOR:=gz}
PX4_GZ_WORLD=${PX4_GZ_WORLD:=default}
PX4_SIM_MODEL=${PX4_SIM_MODEL:=flight_robot}

echo "================================================"
echo "LOADING CUSTOM AIRFRAME: 4030_gz_flight_robot"
echo "Model: $PX4_SIM_MODEL"
echo "================================================"

param set-default SIM_GZ_EN 1

param set-default CA_AIRFRAME 0
param set-default CA_ROTOR_COUNT 4

# Rotor geometry matches the x500_base SDF: rotors at (+-0.174, +-0.174).
# SDF is FLU, PX4 params are FRD, so the y sign flips relative to the SDF.
# KM matches the SDF momentConstant (0.016); sign gives the yaw direction.
param set-default CA_ROTOR0_PX 0.174
param set-default CA_ROTOR0_PY 0.174
param set-default CA_ROTOR0_KM 0.016

param set-default CA_ROTOR1_PX -0.174
param set-default CA_ROTOR1_PY -0.174
param set-default CA_ROTOR1_KM 0.016

param set-default CA_ROTOR2_PX 0.174
param set-default CA_ROTOR2_PY -0.174
param set-default CA_ROTOR2_KM -0.016

param set-default CA_ROTOR3_PX -0.174
param set-default CA_ROTOR3_PY 0.174
param set-default CA_ROTOR3_KM -0.016

param set-default SIM_GZ_EC_FUNC1 101
param set-default SIM_GZ_EC_FUNC2 102
param set-default SIM_GZ_EC_FUNC3 103
param set-default SIM_GZ_EC_FUNC4 104

param set-default SIM_GZ_EC_MIN1 150
param set-default SIM_GZ_EC_MIN2 150
param set-default SIM_GZ_EC_MIN3 150
param set-default SIM_GZ_EC_MIN4 150

param set-default SIM_GZ_EC_MAX1 1000
param set-default SIM_GZ_EC_MAX2 1000
param set-default SIM_GZ_EC_MAX3 1000
param set-default SIM_GZ_EC_MAX4 1000

# 3.41 kg total with 80 N max thrust hovers near 55-60% motor output.
param set-default MPC_THR_HOVER 0.55
# Gentle takeoff and conservative tilt while the platform is being tuned.
param set-default MPC_TKO_SPEED 1.0
param set-default MPC_TILTMAX_AIR 25

param set-default NAV_DLL_ACT 2
