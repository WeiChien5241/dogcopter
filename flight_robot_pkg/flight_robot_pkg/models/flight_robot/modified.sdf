<?xml version="1.0"?>
<sdf version='1.9'>
  <model name='flight_robot'>
  
    <include merge='true'>
      <uri>model://x500_base</uri>
    </include>

    <!-- Rename the merged base_link to avoid conflicts -->
    <!-- The x500_base's base_link is now part of flight_robot -->

    <!-- Your ground robot base -->
    <link name='robot_base_footprint'>  <!-- Renamed to avoid conflict -->
      <pose>0 0 0 0 0 0</pose>  <!-- Position robot base at origin -->
      <inertial>
        <mass>6</mass>
        <inertia>
          <ixx>0.689417</ixx>
          <ixy>0</ixy>
          <ixz>0.025</ixz>
          <iyy>0.92275</iyy>
          <iyz>0</iyz>
          <izz>0.370667</izz>
        </inertia>
      </inertial>
      
      <!-- Base collision -->
      <collision name='base_collision'>
        <pose>0 0 0.2 0 0 0</pose>
        <geometry>
          <box>
            <size>0.6 0.4 0.2</size>
          </box>
        </geometry>
      </collision>
      
      <!-- Caster collision -->
      <collision name='caster_collision'>
        <pose>0.2 0 0.05 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.05</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      
      <!-- Visuals -->
      <visual name='base_visual'>
        <pose>0 0 0.2 0 0 0</pose>
        <geometry>
          <box>
            <size>0.6 0.4 0.2</size>
          </box>
        </geometry>
        <material>
          <diffuse>0 0 0.625 1</diffuse>
        </material>
      </visual>
      
      <visual name='caster_visual'>
        <pose>0.2 0 0.05 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.05</radius>
          </sphere>
        </geometry>
        <material>
          <diffuse>0.625 0.625 0.625 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Left wheel joint and link -->
    <joint name='left_wheel_joint' type='revolute'>
      <parent>robot_base_footprint</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <link name='left_wheel'>
      <pose relative_to='robot_base_footprint'>-0.15 0.225 0.1 1.5708 0 0</pose>
      <inertial>
        <mass>1</mass>
        <inertia>
          <ixx>0.010833</ixx>
          <iyy>0.010833</iyy>
          <izz>0.02</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name='collision'>
        <geometry>
          <cylinder>
            <length>0.05</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='visual'>
        <geometry>
          <cylinder>
            <length>0.05</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Right wheel joint and link -->
    <joint name='right_wheel_joint' type='revolute'>
      <parent>robot_base_footprint</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <link name='right_wheel'>
      <pose relative_to='robot_base_footprint'>-0.15 -0.225 0.1 1.5708 0 0</pose>
      <inertial>
        <mass>1</mass>
        <inertia>
          <ixx>0.010833</ixx>
          <iyy>0.010833</iyy>
          <izz>0.02</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name='collision'>
        <geometry>
          <cylinder>
            <length>0.05</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='visual'>
        <geometry>
          <cylinder>
            <length>0.05</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Attach drone (x500_base's base_link) to robot base -->
    <joint name="robot_to_drone_joint" type="fixed">
      <parent>robot_base_footprint</parent>
      <child>base_link</child>  <!-- This is x500_base's base_link from merge -->
      <pose>0 0 0.4 0 0 0</pose>  <!-- Position drone 0.4m above robot base -->
    </joint>

    <!-- Diff drive for the ground robot -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.45</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
    </plugin>

    <!-- Keep x500's motor plugins (they were merged in) -->
    
  </model>
</sdf>