<?xml version="1.0"?>
<sdf version='1.9'>
  <model name='flight_robot'>

    <!-- Drone frame + sensors (IMU/mag/baro/GPS) from stock x500_base.
         The pose here OVERRIDES x500_base's own model pose (0 0 0.24) so
         base_link truly sits 0.35 m above the robot base, clearing the
         0.30 m-tall body. Motor plugins are inlined below (NOT taken from
         model://x500) so all propulsion tunables live in this one file
         regardless of which x500 copy GZ_SIM_RESOURCE_PATH resolves. -->
    <include merge='true'>
      <uri>model://x500_base</uri>
      <pose>0 0 0.35 0 0 0</pose>
    </include>

    <!-- Motors: motorConstant raised 8.54858e-06 -> 2.0e-05 (~20 N/rotor,
         80 N total) to lift the 3.41 kg hybrid with thrust-to-weight ~2.4.
         Represents the oversized propulsion the real DogCopter needs. -->
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>2.0e-05</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>2.0e-05</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>2.0e-05</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>2.0e-05</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- Ground robot base: 1.0 kg keeps total system at 3.41 kg so the
         upgraded motors hover near 55-60% output. -->
    <link name='robot_base_footprint'>
      <inertial>
        <pose>0 0 0.1 0 0 0</pose>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.0833</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0833</iyy>
          <iyz>0</iyz>
          <izz>0.125</izz>
        </inertia>
      </inertial>

      <collision name='base_collision'>
        <pose>0 0 0.2 0 0 0</pose>
        <geometry>
          <box>
            <size>0.6 0.4 0.2</size>
          </box>
        </geometry>
      </collision>

      <visual name='base_visual'>
        <pose>0 0 0.2 0 0 0</pose>
        <geometry>
          <box>
            <size>0.6 0.4 0.2</size>
          </box>
        </geometry>
        <material>
          <diffuse>0 0 0.625 1</diffuse>
          <ambient>0 0 0.625 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='base_left_wheel_joint' type='revolute'>
      <pose relative_to='robot_base_footprint'>-0.15 0.225 0.1 0 0 0</pose>
      <parent>robot_base_footprint</parent>
      <child>left_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <link name='left_wheel_link'>
      <pose relative_to='base_left_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 1.5707963267948959 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.010833333333333341</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.010833333333333341</iyy>
          <iyz>0</iyz>
          <izz>0.02</izz>
        </inertia>
      </inertial>

      <collision name='left_wheel_link_collision'>
        <pose>0 0 0 1.5707963267948959 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.05</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
      </collision>

      <visual name='left_wheel_link_visual'>
        <pose>0 0 0 1.5707963267948959 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.05</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.625 0.625 0.625 1</diffuse>
          <ambient>0.625 0.625 0.625 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='base_right_wheel_joint' type='revolute'>
      <pose relative_to='robot_base_footprint'>-0.15 -0.225 0.1 0 0 0</pose>
      <parent>robot_base_footprint</parent>
      <child>right_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <link name='right_wheel_link'>
      <pose relative_to='base_right_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 1.5707963267948959 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.010833333333333341</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.010833333333333341</iyy>
          <iyz>0</iyz>
          <izz>0.02</izz>
        </inertia>
      </inertial>

      <collision name='right_wheel_link_collision'>
        <pose>0 0 0 1.5707963267948959 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.05</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
      </collision>

      <visual name='right_wheel_link_visual'>
        <pose>0 0 0 1.5707963267948959 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.05</length>
            <radius>0.1</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.625 0.625 0.625 1</diffuse>
          <ambient>0.625 0.625 0.625 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='base_caster_wheel_joint' type='fixed'>
      <pose relative_to='robot_base_footprint'>0.2 0 0.05 0 0 0</pose>
      <parent>robot_base_footprint</parent>
      <child>caster_wheel_link</child>
    </joint>

    <link name='caster_wheel_link'>
      <pose relative_to='base_caster_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.000125</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000125</iyy>
          <iyz>0</iyz>
          <izz>0.000125</izz>
        </inertia>
      </inertial>

      <collision name='caster_wheel_collision'>
        <geometry>
          <sphere>
            <radius>0.05</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name='caster_wheel_visual'>
        <geometry>
          <sphere>
            <radius>0.05</radius>
          </sphere>
        </geometry>
        <material>
          <diffuse>0.625 0.625 0.625 1</diffuse>
          <ambient>0.625 0.625 0.625 1</ambient>
        </material>
      </visual>
    </link>

    <plugin name='gz::sim::systems::DiffDrive' filename='gz-sim-diff-drive-system'>
      <update_rate>50</update_rate>
      <left_joint>base_left_wheel_joint</left_joint>
      <right_joint>base_right_wheel_joint</right_joint>
      <wheel_separation>0.45</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <command_topic>cmd_vel</command_topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>robot_base_footprint</child_frame_id>
    </plugin>

    <plugin name='gz::sim::systems::JointStatePublisher' filename='gz-sim-joint-state-publisher-system'>
      <joint_name>base_left_wheel_joint</joint_name>
      <joint_name>base_right_wheel_joint</joint_name>
    </plugin>

    <joint name="robot_to_drone_joint" type="fixed">
      <pose relative_to='robot_base_footprint'>0 0 0.35 0 0 0</pose>
      <parent>robot_base_footprint</parent>
      <child>base_link</child>
    </joint>

  </model>
</sdf>
